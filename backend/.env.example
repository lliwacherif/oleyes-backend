SCALWAY_API_KEY=
SCALWAY_BASE_URL=https://api.scaleway.ai/1b0ca8d6-b434-4200-9818-4f56c17232ff/v1
SCALWAY_MODEL=gpt-oss-120b
SCALWAY_TIMEOUT=30
SCALWAY_ANALYSIS_MODEL=qwen3-235b-a22b-instruct-2507
SCALWAY_SYSTEM_PROMPT=You are a CCTV scene analyst. Output a brief label and a concise, human-readable explanation. Avoid technical numbers or class IDs. Keep it short and clear. Base it only on the input text.
SCALWAY_ANALYSIS_MAX_TOKENS=512
SCALWAY_ANALYSIS_TEMPERATURE=0.7
SCALWAY_ANALYSIS_TOP_P=0.8
SCALWAY_ANALYSIS_PRESENCE_PENALTY=0
YOLO_MODEL=yolo26n.pt
YOLO_DEVICE=cpu
YOLO_CONF=0.25
YOLO_MAX_DETECTIONS=100
YOLO_INCLUDE_FRAME=false
YOLO_PREVIEW_EVERY=30
YOLO_LOG_EVERY=1
YOLO_STREAM_EVERY=4
YOLO_VID_STRIDE=1
YOLO_STREAM_BUFFER=true
RTSP_URLS=

# ── PostgreSQL ──
DATABASE_URL=postgresql+asyncpg://liwa:YOUR_PASSWORD@localhost:5432/oleyes

# ── JWT / Auth ──
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
